# TrustGate behavioral scores (optional; app degrades to null when unset)
#
# Copy the keys you need into .env.local and set real values there. With no
# TRUSTGATE_SCORE_API_URL the trust layer returns null everywhere: scores are
# simply not shown and the research agent cites everyone, exactly as before.

# Free reader — TrustGate arc-score API (raw on-chain points). Server applies wallet-rescore
# so catalog badges match trustgated.xyz/oracle playground (e.g. 100 raw → 79 rescored).
# Use {address} as a placeholder, otherwise the wallet is appended as a path segment.
TRUSTGATE_SCORE_API_URL=https://www.trustgated.xyz/api/arc-score/{address}

# Wallet-rescore thresholds — copy from TrustGate production (SCORING_WALLET_* in trustgated.xyz).
# Required for accurate free scores; without these, caps default open and scores stay inflated.
# SCORING_WALLET_NON_ELITE_CAP=79
# SCORING_WALLET_HIGH_ELITE_MIN_DEPLOYMENTS=15
# (see TrustGate frontend/.env.local.example for the full list)

# Paid lookup — TrustGate oracle PROXY (applies wallet-rescore like the site UI).
# Route through trustgated.xyz/api/oracle, NOT oracle.trustgated.xyz directly.
# Server only; never exposed to the client.
TRUSTGATE_ORACLE_URL=https://www.trustgated.xyz/api/oracle/{address}

# Default minimum score for the research agent's --min-trust flag.
# Leave unset (or 0) so nothing is blocked out of the box.
TRUSTGATE_MIN_SCORE=

# Optional: in-memory cache TTL in milliseconds for the free reader (default 300000).
TRUSTGATE_CACHE_TTL_MS=

# Optional: cache TTL in milliseconds for resolved paid scores (default 300000).
TRUSTGATE_PAID_CACHE_TTL_MS=

# Operator wallet = the deployed Attestation contract's immutable platform fee
# recipient (contract owner). Gates the dashboard "Attest fees" tab and the
# fee/balance/withdraw APIs to that wallet only. Public so the client can gate
# the tab; server-side authorization additionally requires a signature from it.
NEXT_PUBLIC_OPERATOR_ADDRESS=0xYourOperatorWalletAddress

# Public "since launch" marketplace metrics count only activity at/after this moment
# (ISO 8601 UTC). Set to the campaign launch time. Server-side only, never public.
CAMPAIGN_START_TIMESTAMP=2026-06-28T00:00:00Z

# WalletConnect / Reown AppKit — mobile wallet connect (allowlist agentcitation.xyz on dashboard.reown.com)
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-project-id-from-reown-dashboard

# Creator marketplace
# REQUIRED for publish + catalog: Supabase vars above + SUPABASE_SERVICE_ROLE_KEY
# REQUIRED for Expand / x402 unlock: SELLER_ADDRESS (+ SELLER_PRIVATE_KEY for withdrawals)
# Optional: wallet scored for markdown demo seeds (defaults to NEXT_PUBLIC_OPERATOR_ADDRESS).
# Use when you publish the whole catalog from one wallet but seeds have placeholder author_wallet values.
# MARKETPLACE_IDENTITY_WALLET=0xYourPublisherWallet

# Optional: TRUSTGATE_SCORE_API_URL (free trust badge), TRUSTGATE_ORACLE_URL (Refresh trust button)
# ATTESTATION_ADDRESS / NEXT_PUBLIC_ATTESTATION_ADDRESS — attest flows on marketplace cards
