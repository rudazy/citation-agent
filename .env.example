# REQUIRED for payment dashboard (payments settle on Arc without these, but won't appear in UI)
# Create a project at https://supabase.com, run migrations in supabase/migrations/, then:
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
# Use either name — code accepts both (Vercel dashboards often use ANON_KEY)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key
# Server-only — records payment_events after each x402 settlement
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Live deployment URL (used by the payment agent)
BASE_URL=https://your-app.vercel.app

# x402 / Circle Nanopayments
# Run `npm run generate-wallets` to auto-generate both seller and buyer wallets
SELLER_ADDRESS=0xYourWalletAddress
SELLER_PRIVATE_KEY=0xYourSellerPrivateKey

# CLI funder wallet (npm run agent only — NOT shared in-app agent wallets)
BUYER_ADDRESS=0xYourBuyerWalletAddress
BUYER_PRIVATE_KEY=0xYourBuyerPrivateKey

# Encrypts per-user agent wallet keys in Supabase (32+ chars; required in production)
AGENT_WALLET_ENCRYPTION_KEY=your-32-char-or-longer-secret

# Arc testnet RPC (use `arc-canteen rpc-url --export` after login for Canteen RPC)
ARC_TESTNET_RPC=https://rpc.testnet.arc.network

# CanteenUSDC wrapper (deploy with `npm run deploy:canteen`)
CANTEEN_USDC_ADDRESS=0xYourCanteenUsdcContractAddress

# Attestation contract (deploy with `npm run deploy:attestation`)
ATTESTATION_ADDRESS=0x595de381357e4dc59a0829d7432a532c73ddf1e1
NEXT_PUBLIC_ATTESTATION_ADDRESS=0x595de381357e4dc59a0829d7432a532c73ddf1e1
ATTESTATION_DEPLOY_BLOCK=48054370

# Arcscan API key for contract verification
ARCSCAN_API_KEY=your-arcscan-api-key

# Circle Gateway facilitator (marketplace trace APIs)
GATEWAY_API=https://gateway-api-testnet.circle.com

# Circle CLI (agent wallets) — accept terms in CI: CIRCLE_ACCEPT_TERMS=1
# circle wallet list --chain ARC-TESTNET --type agent

# LangChain deep agent (OpenAI) — optional
# If omitted, the agent runs in mock mode with scripted tool calls.
OPENAI_API_KEY=your-openai-api-key
